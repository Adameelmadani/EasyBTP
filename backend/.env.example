# PostgreSQL (Docker Compose service "db")
DATABASE_URL="postgresql://easybtp:easybtp@localhost:5432/easybtp?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="change-me-in-production-easybtp-secret"
JWT_EXPIRES_IN="7d"

# CORS (frontend origin)
CLIENT_ORIGIN="http://localhost:5173"
